{
  "name": "opssage",
  "version": "0.1.0",
  "private": true,
  "description": "Support / on-call agent built on flue.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "check": "biome ci .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm --filter @opssage/agent dev",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^20.14.0",
    "lint-staged": "^15.2.10",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm typecheck && pnpm test"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,jsonc}": ["biome check --write --no-errors-on-unmatched"]
  }
}
