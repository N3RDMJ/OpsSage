# OpsSage local dev — copy to .env.local (gitignored).

# HTTP server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Webhook auth — header value Datadog will send.
OPSSAGE_WEBHOOK_SECRET=replace-with-32-byte-random

# flue model — `provider/model` namespace.
FLUE_MODEL=anthropic/claude-sonnet-4-6
# flue sandbox — leave unset for the default virtual (just-bash) sandbox,
# set to `local` to mount the host filesystem (handy for dev).
# FLUE_SANDBOX=local

# Provider transport. PROVIDER=anthropic uses the public Anthropic endpoint;
# PROVIDER=cursor reuses flue's anthropic provider but routes to Cursor's
# Anthropic-compatible base URL.
PROVIDER=anthropic
ANTHROPIC_API_KEY=
CURSOR_API_KEY=
CURSOR_BASE_URL=https://api.cursor.sh/v1

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# GitHub (classic PAT, read-only: repo, read:org)
GITHUB_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Repo allowlist + Slack channel
OPSSAGE_REPOS_FILE=apps/agent/config/repos.yaml
OPSSAGE_ALERT_CHANNEL=#alerts
