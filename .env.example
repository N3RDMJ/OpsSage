# OpsSage local dev — copy to .env.local (gitignored).

# HTTP server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Webhook auth — header value Datadog will send.
OPSSAGE_WEBHOOK_SECRET=replace-with-32-byte-random

# LLM provider. Default uses Anthropic; set PROVIDER=cursor + CURSOR_*
# to route through Cursor's OpenAI-compatible endpoint instead.
PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cursor (used when PROVIDER=cursor)
CURSOR_API_KEY=
CURSOR_BASE_URL=https://api.cursor.sh/v1
CURSOR_MODEL=claude-sonnet-4-6

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# GitHub (classic PAT, read-only: repo, read:org)
GITHUB_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sandbox RPC (set to in-process for local skill loop without docker)
SANDBOX_URL=http://sandbox.opssage.local:8081
SANDBOX_MODE=in-process

# Repo allowlist (path to YAML)
OPSSAGE_REPOS_FILE=apps/agent/config/repos.yaml
