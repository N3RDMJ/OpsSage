# OpsSage local dev — copy to apps/agent/.env.local (gitignored).
# `flue dev` reads .env files from the agent project directory.

# HTTP server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Webhook secret. NB: flue's FlueContext does NOT expose request headers,
# so the agent function can't validate this. v1 relies on the ALB's
# Datadog IP allowlist for ingress auth. Kept here for the day we add a
# Lambda authorizer or path-embedded token.
OPSSAGE_WEBHOOK_SECRET=replace-with-32-byte-random

# flue model — `provider/model-id`. pi-ai resolves credentials from env.
FLUE_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Datadog
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# GitHub (classic PAT, read-only: repo, read:org)
GITHUB_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Langfuse (optional — if unset, tracing no-ops cleanly)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Repo allowlist + Slack channel
OPSSAGE_REPOS_FILE=config/repos.yaml
OPSSAGE_ALERT_CHANNEL=#alerts
