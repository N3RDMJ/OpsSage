{
  "name": "@opssage/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./datadog": {
      "types": "./dist/datadog.d.ts",
      "default": "./dist/datadog.js"
    },
    "./github": {
      "types": "./dist/github.d.ts",
      "default": "./dist/github.js"
    },
    "./langfuse": {
      "types": "./dist/langfuse.d.ts",
      "default": "./dist/langfuse.js"
    },
    "./slack": {
      "types": "./dist/slack.d.ts",
      "default": "./dist/slack.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "default": "./dist/http.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@opssage/config-schema": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.1"
  }
}
